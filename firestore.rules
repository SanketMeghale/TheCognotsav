rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sahilbhatti292005@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /roles/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAdmin();
      allow create: if true; // Allow public registration
      allow update, delete: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin() || (statId == 'global'); 
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /public_status/{teamId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /email_lookup/{emailId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }
  }
}
